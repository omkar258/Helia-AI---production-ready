# ============================================
# Helia AI – Environment Variables
# ============================================

# --- Database ---
POSTGRES_USER=helia_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=helia_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://helia_user:change_me_in_production@localhost:5432/helia_db

# --- JWT Authentication ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ("groq" or "ollama") ---
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- Ollama (only needed if LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- CORS ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- App ---
APP_NAME=Helia AI
APP_VERSION=1.0.0
DEBUG=true
